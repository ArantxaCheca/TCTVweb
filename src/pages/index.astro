---
import MainLayout from '../layouts/MainLayout.astro';
import CTA from '../components/CTA.astro';
---

<MainLayout
  title="Compra de maquinaria industrial y vehículos para exportación | Te Compramos Tu Vehículo"
  description="Compramos maquinaria industrial, vehículos industriales, furgonetas, camiones y turismos en toda España. Valoración rápida, pago seguro y compra para exportación."
>
  <!-- Hero -->
  <section class="hero-full" aria-label="Hero principal">
    <div class="hero-full__bg" style="background-image: url('/images/hero.jpeg')"></div>
    <div class="hero-full__overlay"></div>
    <div class="hero-full__content">
      <h1>Compramos maquinaria industrial y vehículos para exportación</h1>
      <p class="hero-full__subtitle">
        Valoramos y compramos maquinaria, vehículos industriales, furgonetas, camiones y turismos en toda España, con pago seguro y gestión completa.
      </p>
      <a href="/contacto" class="btn btn-primary hero-full__btn">Solicita tu oferta ahora</a>
    </div>
  </section>

  <!-- Trust badges -->
  <section class="trust-badges" aria-label="Ventajas destacadas">
    <div class="container trust-badges__grid">
      <article class="trust-badge">
        <div class="trust-badge__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#e63946" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12l2 2 4-4"/></svg>
        </div>
        <h3 class="trust-badge__title">Valoración sin compromiso</h3>
        <p class="trust-badge__text">Recibe una oferta firme y gratuita en menos de 24 horas.</p>
      </article>
      <article class="trust-badge">
        <div class="trust-badge__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#e63946" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        </div>
        <h3 class="trust-badge__title">Pago seguro</h3>
        <p class="trust-badge__text">Cobras al instante. Sin esperas ni aplazamientos.</p>
      </article>
      <article class="trust-badge">
        <div class="trust-badge__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#e63946" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <h3 class="trust-badge__title">Gestión de documentación</h3>
        <p class="trust-badge__text">Nos encargamos de todos los trámites. Sin costes adicionales.</p>
      </article>
      <article class="trust-badge">
        <div class="trust-badge__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#e63946" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
        </div>
        <h3 class="trust-badge__title">Compra para exportación</h3>
        <p class="trust-badge__text">Accedemos a mercados globales para ofrecerte el mejor precio.</p>
      </article>
    </div>
  </section>

  <!-- Qué compramos -->
  <section class="section-what" aria-label="Qué compramos">
    <div class="container">
      <h2 class="section-title">Maquinaria y vehículos que compramos</h2>
      <div class="what-grid">
        <a href="/servicios" class="what-card">
          <div class="what-card__img">
            <img src="/images/pexels-construccion-total-2464540-8809464.jpg.jpeg" alt="Compra de maquinaria industrial para exportación" loading="lazy" />
          </div>
          <div class="what-card__body">
            <h3>Maquinaria industrial</h3>
            <p>Compramos tornos, fresadoras, prensas, equipos de construcción y maquinaria pesada para exportación.</p>
            <span class="what-card__link">Ver más →</span>
          </div>
        </a>
        <a href="/servicios" class="what-card">
          <div class="what-card__img">
            <img src="/images/pexels-wolfgang-weiser-467045605-33355697.jpg.jpeg" alt="Compra de vehículos industriales" loading="lazy" />
          </div>
          <div class="what-card__body">
            <h3>Vehículos industriales</h3>
            <p>Adquirimos tráileres, camiones rígidos, vehículos comerciales y flotas enteras.</p>
            <span class="what-card__link">Ver más →</span>
          </div>
        </a>
        <a href="/servicios" class="what-card">
          <div class="what-card__img">
            <img src="/images/Ford-Transit.jpg" alt="Compra de furgonetas y camiones" loading="lazy" />
          </div>
          <div class="what-card__body">
            <h3>Furgonetas y camiones</h3>
            <p>Te compramos furgonetas isotérmicas, de carga, camiones frigoríficos y vehículos comerciales.</p>
            <span class="what-card__link">Ver más →</span>
          </div>
        </a>
        <a href="/servicios" class="what-card">
          <div class="what-card__img">
            <img src="/images/cocherojo.JPG" alt="Compra de turismos" loading="lazy" />
          </div>
          <div class="what-card__body">
            <h3>Turismos</h3>
            <p>Compramos coches de todas las marcas y modelos. Tasación rápida y pago inmediato.</p>
            <span class="what-card__link">Ver más →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Servicios principales -->
  <section class="bg-light" aria-label="Servicios principales">
    <div class="container">
      <h2 class="section-title">Servicios de compra especializada</h2>
      <div class="services-grid">
        <article class="service-card">
          <div class="service-card__icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#1d3557" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3>Compra de maquinaria industrial</h3>
          <p>Somos <strong>compradores de maquinaria industrial</strong> especializados en exportación. Adquirimos equipos de producción, construcción, minería y agricultura. Tasamos cada máquina de forma individual y pagamos al instante.</p>
          <a href="/servicios" class="service-card__link">Ver maquinaria que compramos →</a>
        </article>
        <article class="service-card">
          <div class="service-card__icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#1d3557" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 17h-3"/><path d="M22 11h-7"/><path d="M22 5h-9"/><path d="M2 17h3"/><path d="M2 11h7"/><path d="M2 5h9"/></svg>
          </div>
          <h3>Compra de vehículos industriales</h3>
          <p>Si necesitas <strong>vender vehículos industriales</strong>, te ofrecemos la mejor tasación. Compramos camiones, tráileres, furgonetas y toda clase de vehículos comerciales. Gestión rápida y pago seguro.</p>
          <a href="/servicios" class="service-card__link">Ver servicios de compra →</a>
        </article>
        <article class="service-card">
          <div class="service-card__icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#1d3557" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><rect x="16" y="8" width="7" height="8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          </div>
          <h3>Compra de flotas y vehículos comerciales</h3>
          <p>¿Quieres <strong>vender tu furgoneta</strong> o tu flota de vehículos? Compramos lotes completos de vehículos comerciales, furgonetas de carga y camiones de empresa. Pago por lote o unidad.</p>
          <a href="/contacto" class="service-card__link">Solicitar valoración →</a>
        </article>
        <article class="service-card">
          <div class="service-card__icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#1d3557" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
          </div>
          <h3>Compra para exportación</h3>
          <p>Somos expertos en <strong>compra para exportación</strong> de maquinaria industrial y vehículos. Trabajamos con compradores internacionales para ofrecerte precios muy superiores a los del mercado local.</p>
          <a href="/servicios" class="service-card__link">Más sobre exportación →</a>
        </article>
      </div>
    </div>
  </section>

  <!-- Cómo funciona -->
  <section aria-label="Cómo funciona el proceso">
    <div class="container">
      <h2 class="section-title">Cómo vender tu maquinaria o vehículo</h2>
      <div class="steps">
        <div class="step">
          <span class="step__number">1</span>
          <h3>Contacta con nosotros</h3>
          <p>Rellena el formulario, llámanos o escríbenos. Cuéntanos qué quieres vender y recibirás una primera valoración en minutos.</p>
        </div>
        <div class="step">
          <span class="step__number">2</span>
          <h3>Recibe una valoración</h3>
          <p>Te enviamos una oferta firme y sin compromiso. Tasamos tu maquinaria o vehículo al mejor precio del mercado.</p>
        </div>
        <div class="step">
          <span class="step__number">3</span>
          <h3>Acepta la oferta</h3>
          <p>Si te convence, aceptas y nosotros gestionamos toda la documentación. Sin papeleo para ti.</p>
        </div>
        <div class="step">
          <span class="step__number">4</span>
          <h3>Pago seguro y recogida</h3>
          <p>Recibes el pago de forma inmediata y coordinamos la recogida donde nos indiques.</p>
        </div>
      </div>
      <p class="text-center mt-2">
        <a href="/contacto" class="btn btn-secondary">Solicita tu oferta ahora</a>
      </p>
    </div>
  </section>

  <!-- Por qué elegirnos -->
  <section class="bg-light why-section" aria-label="Por qué elegirnos">
    <div class="container why-section__grid">
      <div class="why-section__image">
        <img src="/images/pexels-bylukemiller-29566901.jpg.jpeg" alt="Compradores de maquinaria industrial con experiencia internacional" loading="lazy" />
      </div>
      <div class="why-section__content">
        <h2>Por qué elegir Te Compramos Tu Vehículo</h2>
        <ul class="why-list">
          <li>
            <strong>Especialización en exportación:</strong> Accedemos a mercados internacionales para ofrecerte precios más altos que cualquier comprador local.
          </li>
          <li>
            <strong>Rapidez y eficacia:</strong> Recibe una oferta en menos de 24 horas y cobra al instante. Sin esperas ni procesos largos.
          </li>
          <li>
            <strong>Transparencia total:</strong> Te explicamos cómo tasamos cada máquina y vehículo. Sin sorpresas ni comisiones ocultas.
          </li>
          <li>
            <strong>Gestión integral gratuita:</strong> Nos encargamos de toda la documentación, transferencias y trámites administrativos.
          </li>
          <li>
            <strong>Experiencia real:</strong> Llevamos más de 10 años comprando maquinaria industrial, vehículos industriales, furgonetas, camiones y turismos.
          </li>
        </ul>
        <a href="/sobre-nosotros" class="btn btn-secondary">Conoce más sobre nosotros</a>
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <CTA
    heading="¿Quieres vender tu maquinaria o vehículo?"
    text="Solicita una valoración sin compromiso y recibe una oferta adaptada a tu caso."
    label="Solicita tu oferta ahora"
    href="/contacto"
  />
</MainLayout>

<style>
  /* =============================================
     HERO FULL
  ============================================= */
  .hero-full {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    overflow: hidden;
    padding-top: 80px;
  }

  .hero-full__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 30%;
    background-repeat: no-repeat;
  }

  .hero-full__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(0,0,0,.78) 0%, rgba(0,0,0,.55) 38%, rgba(0,0,0,.25) 70%, rgba(0,0,0,.15) 100%);
  }

  .hero-full__content {
    position: relative;
    z-index: 2;
    color: #fff;
    max-width: 1100px;
    width: 72%;
    padding: 2rem 1.5rem;
    padding-left: clamp(2rem, 5vw, 4rem);
  }

  .hero-full__content h1 {
    font-size: clamp(3rem, 4.5vw, 5.2rem);
    color: #fff;
    margin-bottom: 1.25rem;
    line-height: 1.05;
    font-weight: 800;
  }

  .hero-full__subtitle {
    font-size: clamp(1.1rem, 1.3vw, 1.4rem);
    line-height: 1.55;
    opacity: 0.9;
    margin-bottom: 2rem;
  }

  .hero-full__btn {
    font-size: 1.1rem;
    padding: 18px 48px;
    width: 100%;
    max-width: 500px;
    text-align: center;
  }

  /* =============================================
     TRUST BADGES
  ============================================= */
  .trust-badges {
    padding: 3rem 0;
    background: #fff;
    border-bottom: 1px solid #eee;
  }

  .trust-badges__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .trust-badge {
    text-align: center;
    padding: 1rem 0.75rem;
  }

  .trust-badge__icon {
    margin-bottom: 0.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    background: rgba(230, 57, 70, 0.08);
    border-radius: 50%;
  }

  .trust-badge__title {
    font-size: 1rem;
    color: #1d3557;
    margin-bottom: 0.4rem;
  }

  .trust-badge__text {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.5;
  }

  /* =============================================
     WHAT CARDS
  ============================================= */
  .what-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .what-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    color: inherit;
    text-decoration: none;
  }

  .what-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    text-decoration: none;
  }

  .what-card__img {
    width: 100%;
    height: 200px;
    overflow: hidden;
  }

  .what-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .what-card:hover .what-card__img img {
    transform: scale(1.08);
  }

  .what-card__body {
    padding: 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .what-card__body h3 {
    font-size: 1.1rem;
    color: #1d3557;
    margin-bottom: 0.5rem;
  }

  .what-card__body p {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.6;
    flex: 1;
    margin-bottom: 0.75rem;
  }

  .what-card__link {
    font-size: 0.9rem;
    font-weight: 600;
    color: #e63946;
  }

  /* =============================================
     SERVICES CARDS
  ============================================= */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    background: #fff;
    border-radius: 10px;
    padding: 2rem;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    transition: box-shadow 0.3s ease;
  }

  .service-card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
  }

  .service-card__icon {
    margin-bottom: 1rem;
  }

  .service-card h3 {
    font-size: 1.15rem;
    color: #1d3557;
    margin-bottom: 0.75rem;
  }

  .service-card p {
    font-size: 0.95rem;
    color: #333;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .service-card__link {
    font-size: 0.9rem;
    font-weight: 600;
    color: #e63946;
  }

  /* =============================================
     WHY SECTION
  ============================================= */
  .why-section__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .why-section__image img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  }

  .why-section__content h2 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    color: #111;
  }

  .why-list {
    list-style: none;
    padding: 0;
    margin-bottom: 1.5rem;
  }

  .why-list li {
    padding: 0.75rem 0;
    padding-left: 1.75rem;
    position: relative;
    font-size: 0.95rem;
    color: #333;
    line-height: 1.6;
    border-bottom: 1px solid #f0f0f0;
  }

  .why-list li:last-child {
    border-bottom: none;
  }

  .why-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #e63946;
    font-weight: 700;
    font-size: 1.1rem;
  }

  /* =============================================
     RESPONSIVE
  ============================================= */
  @media (max-width: 1024px) {
    .hero-full__content {
      width: 85%;
      padding-left: clamp(1.5rem, 4vw, 3rem);
    }

    .hero-full__content h1 {
      font-size: clamp(2.6rem, 4vw, 3.2rem);
    }

    .trust-badges__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .what-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .why-section__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .why-section__image {
      order: -1;
    }
  }

  @media (max-width: 768px) {
    .hero-full {
      min-height: 70vh;
      padding-top: 70px;
    }

    .hero-full__content {
      width: 100%;
      padding-inline: 1.25rem;
    }

    .hero-full__content h1 {
      font-size: clamp(2.4rem, 10vw, 3.4rem);
    }

    .hero-full__subtitle {
      font-size: 1rem;
    }

    .hero-full__btn {
      width: 100%;
      max-width: 360px;
    }

    .trust-badges__grid {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .trust-badge {
      padding: 0.75rem;
    }

    .what-grid {
      grid-template-columns: 1fr;
    }

    .what-card__img {
      height: 180px;
    }

    .why-section__content h2 {
      font-size: 1.6rem;
    }
  }

  @media (max-width: 480px) {
    .hero-full__btn {
      font-size: 1rem;
      padding: 16px 36px;
      max-width: none;
    }

    .service-card {
      padding: 1.5rem;
    }

    .hero-full__content h1 {
      font-size: clamp(2rem, 12vw, 2.6rem);
    }

    .hero-full {
      min-height: 60vh;
    }
  }
</style>
