---
import MainLayout from '../layouts/MainLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<MainLayout
  title="Contacto | Vende tu Maquinaria o Vehículo | Te Compramos Tu Vehículo"
  description="Contacta con Te Compramos Tu Vehículo para vender tu maquinaria industrial, camión, furgoneta o turismo. Solicita tu valoración gratuita sin compromiso."
  canonical="/contacto"
>
  <section class="page-hero" aria-label="Contacto">
    <div class="page-hero__bg" style="background-image: url('/images/contacto.png')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content">
      <h1>Contacta con nosotros</h1>
      <p class="page-hero__subtitle">
        ¿Tienes maquinaria industrial, un camión, una furgoneta o un turismo que quieras vender?
        Cuéntanos qué tienes y te haremos una oferta.
      </p>
      <a href="#contact-form" class="btn btn-primary page-hero__btn">Contáctanos</a>
    </div>
  </section>

  <section id="contact-form" style="scroll-margin-top: 100px">
    <div class="container">
      <h2 class="section-title">Solicita tu valoración gratuita</h2>

      <div class="trust-bar">
        <div class="trust-card">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <div class="trust-card__content">
            <strong>Valoración gratuita y sin compromiso</strong>
            <span>Revisamos tu vehículo o maquinaria sin coste.</span>
          </div>
        </div>
        <div class="trust-card">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
          <div class="trust-card__content">
            <strong>Propuesta personalizada</strong>
            <span>Analizamos tu caso para ofrecerte la mejor opción.</span>
          </div>
        </div>
        <div class="trust-card">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          <div class="trust-card__content">
            <strong>Gestión documental incluida</strong>
            <span>Nos encargamos del proceso para que no tengas que preocuparte.</span>
          </div>
        </div>
      </div>
      <div class="contact-grid">
        <div class="contact-info">
          <p>
            Solicita una valoración gratuita. Revisaremos tu vehículo o maquinaria y te enviaremos una propuesta personalizada, sin compromiso.
          </p>

          <h3>Datos de contacto</h3>
          <ul class="contact-data">
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <span><strong>Teléfono:</strong> <a href="tel:+34663452674" style="color:inherit;text-decoration:none">+34 663 45 26 74</a></span>
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <span><strong>Email:</strong> <a href="mailto:Imperialcars2026@yahoo.com" style="color:inherit;text-decoration:none">Imperialcars2026@yahoo.com</a></span>
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
              <span><strong>Horario:</strong> Lun–Vie 9:00–19:00</span>
            </li>
          </ul>

          <h3 class="mt-2">¿Qué ocurre después?</h3>
          <ul class="list-check">
            <li>Revisamos tu solicitud.</li>
            <li>Nuestro equipo revisa tu solicitud y se pone en contacto contigo.</li>
            <li>Valoramos tu vehículo o maquinaria.</li>
            <li>Te enviamos una oferta firme y sin compromiso.</li>
            <li>Si aceptas, gestionamos toda la documentación.</li>
          </ul>
        </div>
        <ContactForm />
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-hero {
    position: relative;
    min-height: 52vh;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    overflow: hidden;
  }
  .page-hero__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 30%;
    background-repeat: no-repeat;
  }
  .page-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(0,0,0,.78) 0%, rgba(0,0,0,.55) 38%, rgba(0,0,0,.25) 70%, rgba(0,0,0,.15) 100%);
  }
  .page-hero__content {
    position: relative;
    z-index: 2;
    color: #fff;
    max-width: 1100px;
    width: 85%;
    padding: 10rem 1.5rem 0.5rem;
    padding-left: clamp(2rem, 5vw, 4rem);
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .page-hero__content h1 {
    font-size: clamp(2.55rem, 4vw, 3.5rem);
    color: #fff;
    margin: 0 0 2rem 0;
    line-height: 1.08;
    font-weight: 800;
  }
  .page-hero__subtitle {
    font-size: clamp(1rem, 1.2vw, 1.3rem);
    line-height: 1.55;
    opacity: .9;
    margin: 0 0 2rem 0;
    max-width: 680px;
  }
  .page-hero__btn {
    font-size: 1.1rem;
    padding: 12px 48px;
    width: 100%;
    max-width: 450px;
    text-align: center;
  }

  @media (max-width: 1024px) {
    .page-hero__content {
      width: 85%;
    }
  }

  @media (min-width: 1025px) {
    .page-hero__content {
      max-width: none;
      width: 760px;
    }
    .page-hero__content h1 {
      white-space: nowrap;
    }
  }

  @media (max-width: 768px) {
    .page-hero {
      min-height: 48vh;
    }
    .page-hero__content {
      width: 100%;
      padding-inline: 1.25rem;
    }
    .page-hero__content h1 {
      font-size: clamp(1.6rem, 6vw, 2.2rem);
    }
    .page-hero__subtitle {
      font-size: 1rem;
    }
    .page-hero__btn {
      max-width: 360px;
    }
  }

  @media (max-width: 480px) {
    .page-hero__btn {
      font-size: 1rem;
      padding: 12px 36px;
      max-width: none;
    }
    .page-hero__content h1 {
      font-size: clamp(1.4rem, 7vw, 1.85rem);
    }
  }

  /* ==============================
     CONTACT SECTION OVERRIDES
  ============================== */
  section {
    padding: 3.2rem 0;
  }
  .section-title {
    margin-bottom: 2.5rem;
  }
  .contact-grid {
    grid-template-columns: 42% 1fr;
    gap: 3rem;
  }
  .contact-info > p {
    margin-bottom: 2rem;
    line-height: 1.65;
  }
  .contact-info h3 {
    margin-bottom: 0.75rem;
  }
  .contact-info .mt-2 {
    margin-top: 2.5rem;
  }
  .contact-data {
    list-style: none;
    padding: 0;
    margin-bottom: 0;
  }
  .contact-data li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
    font-size: 0.95rem;
  }
  .contact-data li svg {
    flex-shrink: 0;
    color: var(--color-primary);
  }
  .contact-data li a:hover {
    text-decoration: underline;
  }
  .contact-info .list-check li {
    margin-bottom: 0.75rem;
    font-size: 0.9rem;
  }

  /* ==============================
     TRUST BAR
  ============================== */
  .trust-bar {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 3rem;
  }
  .trust-card {
    display: flex;
    align-items: center;
    gap: 16px;
    background: #fff;
    border: 1px solid #eaeaea;
    border-radius: 12px;
    padding: 20px 24px;
    box-shadow: 0 2px 8px rgba(0,0,0,.04);
  }
  .trust-card svg {
    flex-shrink: 0;
  }
  .trust-card__content {
    display: flex;
    flex-direction: column;
  }
  .trust-card__content strong {
    font-size: 0.92rem;
    font-weight: 700;
    color: #111;
    line-height: 1.3;
    margin-bottom: 2px;
  }
  .trust-card__content span {
    font-size: 0.8rem;
    color: #888;
    line-height: 1.3;
  }

  @media (max-width: 768px) {
    section {
      padding: 2.5rem 0;
    }
    .section-title {
      margin-bottom: 2rem;
    }
    .trust-bar {
      grid-template-columns: 1fr;
      gap: 16px;
      margin-bottom: 2rem;
    }
    .trust-card {
      padding: 16px 20px;
    }
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .contact-data li {
      font-size: 0.9rem;
    }
  }
</style>
