<form class="contact-form" id="contact-form-element">
  <label for="nombre">Nombre completo</label>
  <input type="text" id="nombre" name="nombre" required />

  <label for="email">Correo electrónico</label>
  <input type="email" id="email" name="email" required />

  <label for="telefono">Teléfono</label>
  <input type="tel" id="telefono" name="telefono" required />

  <label for="tipo">Tipo de vehículo o maquinaria</label>
  <select id="tipo" name="tipo" required>
    <option value="">Selecciona una opción</option>
    <option value="maquinaria-industrial">Maquinaria industrial</option>
    <option value="vehiculo-industrial">Vehículo industrial</option>
    <option value="camion">Camión</option>
    <option value="furgoneta">Furgoneta</option>
    <option value="turismo">Turismo</option>
    <option value="otro">Otro</option>
  </select>

  <label for="mensaje">Cuéntanos qué quieres vender (marca, modelo, año)</label>
  <textarea id="mensaje" name="mensaje" rows="3" required></textarea>

  <p class="form-trust">Tus datos solo se utilizarán para elaborar tu valoración. Nunca los compartiremos con terceros.</p>

  <div id="form-result" class="form-result" style="display:none;" role="alert"></div>

  <button type="submit" class="btn btn-primary">Quiero mi valoración gratuita</button>
</form>

<script>
  const form = document.getElementById('contact-form-element');
  const result = document.getElementById('form-result');

  if (form && result) {
    form.addEventListener('submit', async function (e) {
      e.preventDefault();

      const nombre = document.getElementById('nombre')?.value.trim();
      const email = document.getElementById('email')?.value.trim();
      const telefono = document.getElementById('telefono')?.value.trim();
      const tipo = document.getElementById('tipo')?.value;
      const mensaje = document.getElementById('mensaje')?.value.trim();

      if (!nombre || !email || !telefono || !tipo || !mensaje) {
        result.textContent = 'Todos los campos son obligatorios.';
        result.className = 'form-result form-result--error';
        result.style.display = 'block';
        return;
      }

      const btn = form.querySelector('button[type="submit"]');
      if (!btn) return;

      btn.disabled = true;
      btn.textContent = 'Enviando...';

      try {
        const response = await fetch('/api/contacto', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            nombre,
            email,
            telefono,
            tipo_vehiculo: tipo,
            vehiculo_descripcion: mensaje,
          }),
        });

        const data = await response.json();

        if (response.ok) {
          result.textContent = 'Gracias. Hemos recibido tu solicitud y nos pondremos en contacto contigo lo antes posible.';
          result.className = 'form-result form-result--success';
          result.style.display = 'block';
          form.reset();
          setTimeout(() => {
          result.style.display = 'none';
          }, 5000);
        } else {
          result.textContent = data.error || 'No se ha podido enviar el formulario.';
          result.className = 'form-result form-result--error';
          result.style.display = 'block';
        }
      } catch (error) {
        result.textContent = 'No se ha podido enviar el formulario. Inténtalo de nuevo.';
        result.className = 'form-result form-result--error';
        result.style.display = 'block';
      } finally {
        btn.disabled = false;
        btn.textContent = 'Quiero mi valoración gratuita';
      }
    });
  }
</script>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 22px;
  }

  .contact-form label {
    font-size: 0.9rem;
    font-weight: 600;
    color: #111;
    margin-bottom: 2px;
  }

  .contact-form input,
  .contact-form textarea,
  .contact-form select {
    padding: 0.65rem 0.75rem;
    font-size: 0.95rem;
    border: 1px solid #ccc;
    border-radius: 6px;
    font-family: inherit;
  }

  .contact-form input:focus,
  .contact-form textarea:focus,
  .contact-form select:focus {
    outline: none;
    border-color: #457b9d;
    box-shadow: 0 0 0 2px rgba(69, 123, 157, 0.2);
  }

  .contact-form button[type="submit"] {
    width: 100%;
    text-align: center;
    padding: 0.85rem;
    font-size: 1rem;
    background-color: var(--color-red);
    border-color: var(--color-red);
  }

  .contact-form button[type="submit"]:hover {
    background-color: var(--color-red-hover);
    border-color: var(--color-red-hover);
  }

  .form-trust {
    font-size: 0.78rem;
    color: #888;
    margin: 0.25rem 0 12px 0;
    line-height: 1.4;
  }

  .form-result {
    padding: 12px 16px;
    border-radius: 6px;
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 8px 0;
  }

  .form-result--success {
    background-color: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
  }

  .form-result--error {
    background-color: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
  }

  @media (max-width: 480px) {
    .contact-form label {
      font-size: 0.85rem;
    }

    .contact-form input,
    .contact-form textarea,
    .contact-form select {
      padding: 0.6rem 0.7rem;
      font-size: 0.9rem;
    }

    .contact-form button[type="submit"] {
      padding: 0.8rem;
      font-size: 0.95rem;
    }
  }
</style>