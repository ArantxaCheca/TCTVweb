---
export interface Props {
  heading?: string;
  text?: string;
  label?: string;
  href?: string;
}

const {
  heading = '¿Tienes algo que vender?',
  text = 'Solicita una valoración sin compromiso y descubre cuánto puedes obtener por tu maquinaria o vehículo.',
  label = 'Solicitar valoración',
  href = '/contacto',
} = Astro.props;
---

<section class="cta-section">
  <div class="container cta-section__inner">
    <h2>{heading}</h2>
    <p>{text}</p>
    <a href={href} class="btn btn-primary">{label}</a>
  </div>
</section>

<style>
  .cta-section {
    background: linear-gradient(135deg, #1d3557, #457b9d);
    color: #fff;
    text-align: center;
    padding: 4rem 0;
  }

  .cta-section__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .cta-section h2 {
    font-size: 2rem;
    color: #fff;
  }

  .cta-section p {
    font-size: 1.1rem;
    max-width: 600px;
    opacity: 0.9;
  }
</style>
